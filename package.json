{
  "name": "gothamform",
  "version": "0.0.52",
  "description": "Gotham.Studio | Nuxt 4 form module",
  "repository": "Gothamsiti/GothamForm",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./server/utils/emailtemplate": "./dist/runtime/server/utils/emailtemplate.js"
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "npm run dev:prepare",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "release": "changelogen --release && git push --follow-tags",
    "release:patch:auto": "bash ./scripts/release-patch-auto.sh",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.8",
    "@storyblok/vue": "^11.0.0",
    "@vuepic/vue-datepicker": "^14.0.0",
    "date-fns": "^4.4.0",
    "lodash.debounce": "^4.0.8"
  },
  "devDependencies": {
    "@nuxt/devtools": "4.0.0-alpha.7",
    "@nuxt/eslint-config": "^1.16.0",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.8",
    "@nuxt/test-utils": "^4.0.3",
    "@types/node": "latest",
    "changelogen": "^0.6.2",
    "eslint": "^10.5.0",
    "nuxt": "^4.4.8",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}
